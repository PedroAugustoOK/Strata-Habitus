[user]
    name  = Pedro Augusto
    email = # TODO: adicionar email

[core]
    editor     = nvim
    autocrlf   = input
    whitespace = trailing-space,space-before-tab

[init]
    defaultBranch = main

[pull]
    rebase = false

[push]
    autoSetupRemote = true

[merge]
    conflictstyle = diff3

[diff]
    colorMoved = zebra

[alias]
    st  = status
    co  = checkout
    br  = branch
    lg  = log --oneline --graph --decorate --all
    undo = reset --soft HEAD~1
    wip  = commit -am "wip"
